{
  "name": "kraking",
  "version": "1.0.0",
  "description": "Automated trades and transfers for Kraken exchange",
  "main": "dist/main.js",
  "scripts": {
    "start": "npm run build && electron .",
    "build": "tsc",
    "watch": "tsc -w",
    "dev": "npm run build && electron . --dev",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "build:backend": "cd src/backend && call venv\\Scripts\\activate && pyinstaller server.spec",
    "build:all": "npm run build && npm run build:backend && npm run dist"
  },
  "build": {
    "appId": "com.kraking.app",
    "productName": "Kraking",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/index.html",
      "src/donation.js",
      "src/app/**/*",
      "src/assets/**/*",
      "!src/**/*.ts",
      "!src/backend/**/*"
    ],
    "extraResources": [
      {
        "from": "src/backend/dist/KrakingServer.exe",
        "to": "backend/KrakingServer.exe"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "electron": "^28.2.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.3.3"
  }
}
